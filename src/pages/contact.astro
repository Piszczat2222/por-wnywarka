---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';
---

<BaseLayout title={`Contact | ${SITE.name}`} description={`Get in touch with the ${SITE.name} team.`}>
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-extrabold text-gray-900">Contact</h1>
    <p class="mt-4 text-lg text-gray-600">
      Have a product suggestion, correction, or partnership inquiry? We'd love to hear from you.
    </p>

    <div class="mt-10 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
      <h2 class="text-lg font-bold text-gray-900">Email us</h2>
      <p class="mt-3 text-gray-600">
        The fastest way to reach us:
      </p>
      <a
        href={`mailto:${SITE.email}`}
        class="mt-4 inline-flex items-center gap-2 text-lg font-semibold text-brand-600 hover:text-brand-700"
      >
        {SITE.email}
      </a>
      <p class="mt-6 text-sm text-gray-500">
        We typically respond within 2–3 business days.
      </p>
    </div>

    <div class="mt-8 rounded-xl border border-gray-100 bg-gray-50 p-6 text-sm text-gray-600">
      <p>
        <strong>Note:</strong> {SITE.name} does not sell products directly. For order support, returns,
        or warranty questions, please contact Amazon or the product manufacturer.
      </p>
    </div>
  </div>
</BaseLayout>
