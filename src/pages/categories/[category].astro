---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, getCategoryKeys, type CategoryKey } from '../../lib/categories';
import { buildPageTitle, absoluteUrl } from '../../lib/seo';
import { breadcrumbSchema, collectionPageSchema, mergeJsonLd } from '../../lib/structured-data';

export async function getStaticPaths() {
  return getCategoryKeys().map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params as { category: CategoryKey };
const meta = CATEGORIES[category];

if (!meta) {
  return Astro.redirect('/reviews');
}

const articles = (await getCollection('articles'))
  .filter((a) => a.data.category === category)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const pageUrl = absoluteUrl(`/categories/${category}`);
const jsonLd = mergeJsonLd(
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: meta.label, path: `/categories/${category}` },
  ]),
  collectionPageSchema({
    name: meta.seoTitle,
    description: meta.seoDescription,
    url: pageUrl,
    numberOfItems: articles.length,
  }),
);
---

<BaseLayout
  title={buildPageTitle(meta.seoTitle)}
  description={meta.seoDescription}
  jsonLd={jsonLd}
>
  <div class={`bg-gradient-to-br ${meta.accent} px-4 py-16 text-white sm:px-6`}>
    <div class="mx-auto max-w-6xl">
      <span class="text-4xl" aria-hidden="true">{meta.icon}</span>
      <h1 class="mt-4 text-4xl font-extrabold">{meta.label}</h1>
      <p class="mt-3 max-w-2xl text-lg text-white/90">{meta.description}</p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    {
      articles.length === 0 ? (
        <p class="text-gray-600">No reviews in this category yet. Check back soon!</p>
      ) : (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.cardTitle}
              excerpt={article.data.cardExcerpt}
              href={`/articles/${article.id}`}
              category={article.data.categoryLabel}
              categoryColor={meta.color}
              articleType={article.data.articleType}
            />
          ))}
        </div>
      )
    }

    <div class="mt-12 text-center">
      <a href="/reviews" class="text-sm font-semibold text-brand-600 hover:text-brand-700">
        ← Back to all reviews
      </a>
    </div>
  </div>
</BaseLayout>
