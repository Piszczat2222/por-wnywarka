---
import { AMAZON_DISCLOSURE, FTC_DISCLOSURE, SITE, POPULAR_ARTICLES } from '../lib/site';
---

<footer class="border-t border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-8 md:grid-cols-5">
      <div>
        <p class="text-lg font-bold">
          <span class="text-gray-900">Alt</span><span class="text-brand-600">Pik</span>
        </p>
        <p class="mt-2 text-sm text-gray-600">{SITE.description}</p>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-900">Explore</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/" class="text-gray-600 hover:text-brand-600">Home</a></li>
          <li><a href="/reviews?type=listicle" class="text-gray-600 hover:text-brand-600">Top 10 Guides</a></li>
          <li><a href="/reviews" class="text-gray-600 hover:text-brand-600">All Reviews</a></li>
          <li><a href="/about" class="text-gray-600 hover:text-brand-600">About</a></li>
          <li><a href="/contact" class="text-gray-600 hover:text-brand-600">Contact</a></li>
          <li><a href="/rss.xml" class="text-gray-600 hover:text-brand-600">RSS Feed</a></li>
          <li><a href="/privacy" class="text-gray-600 hover:text-brand-600">Privacy Policy</a></li>
          <li><a href="/terms" class="text-gray-600 hover:text-brand-600">Terms of Service</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-900">Categories</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/categories/tech" class="text-gray-600 hover:text-brand-600">Tech & Gadgets</a></li>
          <li><a href="/categories/home" class="text-gray-600 hover:text-brand-600">Home Aesthetic</a></li>
          <li><a href="/categories/travel" class="text-gray-600 hover:text-brand-600">Travel & Lifestyle</a></li>
          <li><a href="/categories/beauty" class="text-gray-600 hover:text-brand-600">Beauty & Hair</a></li>
          <li><a href="/categories/fitness" class="text-gray-600 hover:text-brand-600">Fitness & Activewear</a></li>
          <li><a href="/categories/kitchen" class="text-gray-600 hover:text-brand-600">Kitchen & Appliances</a></li>
          <li><a href="/categories/pets" class="text-gray-600 hover:text-brand-600">Pets & Dogs</a></li>
          <li><a href="/categories/office" class="text-gray-600 hover:text-brand-600">Office & WFH</a></li>
          <li><a href="/categories/baby" class="text-gray-600 hover:text-brand-600">Baby & Kids</a></li>
          <li><a href="/categories/automotive" class="text-gray-600 hover:text-brand-600">Car & Travel</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-900">Popular</h2>
        <ul class="mt-3 space-y-2 text-sm">
          {
            POPULAR_ARTICLES.map(({ href, label }) => (
              <li>
                <a href={href} class="text-gray-600 hover:text-brand-600">{label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-900">Disclosures</h2>
        <p class="mt-3 text-xs leading-relaxed text-gray-500">{AMAZON_DISCLOSURE}</p>
        <p class="mt-3 text-xs leading-relaxed text-gray-500">{FTC_DISCLOSURE}</p>
      </div>
    </div>

    <p class="mt-10 border-t border-gray-200 pt-6 text-center text-xs text-gray-400">
      © {new Date().getFullYear()} {SITE.name}. All rights reserved.
    </p>
  </div>
</footer>
