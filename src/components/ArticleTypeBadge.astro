---
interface Props {
  type: 'comparison' | 'listicle';
}

const { type } = Astro.props;
const label = type === 'listicle' ? 'Top 10 Guide' : 'Comparison';
const color =
  type === 'listicle'
    ? 'bg-violet-100 text-violet-700'
    : 'bg-gray-100 text-gray-600';
---

<span class:list={['inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold', color]}>
  {label}
</span>
