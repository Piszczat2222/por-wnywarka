---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="my-10 border-t border-gray-200 pt-10" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="mb-6 text-2xl font-bold text-gray-900">
    Frequently Asked Questions
  </h2>
  <div class="space-y-3">
    {
      items.map((item) => (
        <details class="group rounded-xl border border-gray-200 bg-white open:border-brand-200 open:bg-brand-50/30">
          <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-gray-900 marker:content-none [&::-webkit-details-marker]:hidden">
            <span class="flex items-start justify-between gap-4">
              {item.question}
              <span class="mt-0.5 shrink-0 text-brand-600 transition-transform group-open:rotate-45">+</span>
            </span>
          </summary>
          <p class="border-t border-gray-100 px-5 pb-4 pt-3 text-sm leading-relaxed text-gray-600">
            {item.answer}
          </p>
        </details>
      ))
    }
  </div>
</section>
