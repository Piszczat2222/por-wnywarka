---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="my-10 grid gap-6 sm:grid-cols-2">
  <div class="rounded-2xl border border-brand-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-bold text-brand-800">Pros</h2>
    <ul class="mt-4 space-y-3">
      {
        pros.map((item) => (
          <li class="flex gap-3 text-sm leading-relaxed text-gray-700">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-700" aria-hidden="true">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            {item}
          </li>
        ))
      }
    </ul>
  </div>
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-bold text-gray-800">Cons</h2>
    <ul class="mt-4 space-y-3">
      {
        cons.map((item) => (
          <li class="flex gap-3 text-sm leading-relaxed text-gray-700">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gray-100 text-gray-500" aria-hidden="true">
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 12H4" />
              </svg>
            </span>
            {item}
          </li>
        ))
      }
    </ul>
  </div>
</div>
