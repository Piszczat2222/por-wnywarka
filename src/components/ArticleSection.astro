---
interface Props {
  title?: string;
  variant?: 'default' | 'muted';
}

const { title, variant = 'default' } = Astro.props;

const wrapperClass =
  variant === 'muted'
    ? 'rounded-2xl border border-gray-200 bg-gray-50 p-6 sm:p-8'
    : '';
---

<section class:list={['my-8', wrapperClass]}>
  {title && <h2 class="mb-4 text-2xl font-bold text-gray-900">{title}</h2>}
  <slot />
</section>
