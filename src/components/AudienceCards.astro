---
interface Props {
  whoItsFor: string[];
  whoShouldSkip: string[];
}

const { whoItsFor, whoShouldSkip } = Astro.props;
---

<div class="my-10 grid gap-6 sm:grid-cols-2">
  <div class="rounded-2xl border border-brand-200 bg-brand-50/50 p-6">
    <h2 class="flex items-center gap-2 text-lg font-bold text-gray-900">
      <span class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-100 text-brand-700" aria-hidden="true">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </span>
      Who this is for
    </h2>
    <ul class="mt-4 space-y-2">
      {
        whoItsFor.map((item) => (
          <li class="flex gap-2 text-sm leading-relaxed text-gray-700">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-500" aria-hidden="true" />
            {item}
          </li>
        ))
      }
    </ul>
  </div>
  <div class="rounded-2xl border border-gray-200 bg-gray-50 p-6">
    <h2 class="flex items-center gap-2 text-lg font-bold text-gray-900">
      <span class="flex h-7 w-7 items-center justify-center rounded-full bg-gray-200 text-gray-600" aria-hidden="true">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </span>
      Who should skip
    </h2>
    <ul class="mt-4 space-y-2">
      {
        whoShouldSkip.map((item) => (
          <li class="flex gap-2 text-sm leading-relaxed text-gray-700">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gray-400" aria-hidden="true" />
            {item}
          </li>
        ))
      }
    </ul>
  </div>
</div>
