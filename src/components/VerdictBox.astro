---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<aside class="my-8 rounded-2xl border border-brand-200 bg-brand-50/60 p-6 sm:p-8">
  <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Quick verdict</p>
  <p class="mt-2 text-base leading-relaxed text-gray-800 sm:text-lg">{text}</p>
</aside>
