---
import { amazonUrl } from '../lib/amazon';

interface Props {
  asin: string;
  productName: string;
  variant?: 'primary' | 'secondary';
}

const { asin, productName, variant = 'primary' } = Astro.props;
const url = amazonUrl(asin);

const baseClass =
  'inline-flex w-full items-center justify-center gap-2 rounded-xl px-6 py-4 text-center text-base font-bold transition-all sm:w-auto';
const variantClass =
  variant === 'primary'
    ? 'bg-brand-600 text-white shadow-lg shadow-brand-600/25 hover:bg-brand-700 hover:shadow-xl'
    : 'border-2 border-brand-600 text-brand-700 hover:bg-brand-50';
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer sponsored"
  class:list={[baseClass, variantClass]}
  aria-label={`Check current price and availability for ${productName} on Amazon`}
>
  <span>Check Current Price &amp; Availability on Amazon</span>
  <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
