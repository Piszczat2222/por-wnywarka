---
import { NAV_LINKS } from '../lib/site';

const currentPath = Astro.url.pathname;

function navPath(href: string): string {
  return href.split('?')[0] || '/';
}

function isActive(href: string): boolean {
  const path = navPath(href);
  return currentPath === path || (path !== '/' && currentPath.startsWith(path));
}
---

<header class="sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-5 sm:px-6 lg:py-6">
    <a href="/" class="group flex items-center gap-1 text-2xl font-bold tracking-tight sm:text-3xl">
      <span class="text-gray-900">Alt</span>
      <span class="text-brand-600 group-hover:text-brand-700">Pik</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {
        NAV_LINKS.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-base font-medium transition-colors hover:text-brand-600',
              isActive(href) ? 'text-brand-600' : 'text-gray-600',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none rounded-lg p-2 text-gray-600 hover:bg-gray-50">
        <span class="sr-only">Open menu</span>
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <nav class="absolute right-0 mt-2 w-48 rounded-xl border border-gray-100 bg-white py-2 shadow-lg">
        {
          NAV_LINKS.map(({ href, label }) => (
            <a href={href} class="block px-4 py-2.5 text-base text-gray-700 hover:bg-gray-50 hover:text-brand-600">
              {label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
